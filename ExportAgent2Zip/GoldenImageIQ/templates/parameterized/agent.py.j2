"""{{ project_name }} — AI Agent with function-calling tools.

Tools are plain async defs registered in TOOLS / TOOL_SCHEMAS / TOOL_MAP.
The agent uses page-level tool isolation via PAGE_ALLOWED_TOOLS and
runs up to MAX_ROUNDS function-calling iterations per chat.
"""

from __future__ import annotations

import json
import logging
import os
from typing import Any, AsyncGenerator

from openai import AsyncAzureOpenAI

log = logging.getLogger(__name__)

MAX_ROUNDS = 10

# ── Azure OpenAI client ────────────────────────────────────────────

_client: AsyncAzureOpenAI | None = None


def _get_client() -> AsyncAzureOpenAI:
    global _client
    if _client is None:
        _client = AsyncAzureOpenAI(
            azure_endpoint=os.environ["AZURE_OPENAI_ENDPOINT"],
            api_version=os.getenv("AZURE_OPENAI_API_VERSION", "2024-12-01-preview"),
        )
    return _client


# ── Tool definitions ───────────────────────────────────────────────
# Each tool is an async def that returns a dict or str.
# Register in TOOL_SCHEMAS (OpenAI function schema) and TOOL_MAP.

{% for tool in additional_tools %}
async def tool_{{ tool.name }}(**kwargs) -> dict:
    """{{ tool.description | default('TODO: implement') }}"""
    # TODO: implement {{ tool.name }}
    return {"status": "not_implemented", "tool": "{{ tool.name }}"}

{% endfor %}

# ── Assessment tools (auto-generated per domain) ───────────────────

{% for domain in _all_domains %}
async def tool_run_{{ domain }}_assessment(**kwargs) -> dict:
    """Run the {{ domain }} assessment pipeline."""
    from app.{{ _project_snake }}_orchestrator import run_assessment
    return await run_assessment("{{ domain }}", **kwargs)

{% endfor %}

# ── Tool registries ────────────────────────────────────────────────

TOOL_SCHEMAS: list[dict] = [
{% for domain in _all_domains %}
    {
        "type": "function",
        "function": {
            "name": "run_{{ domain }}_assessment",
            "description": "Run the {{ domain }} domain assessment — collect evidence, evaluate controls, generate reports.",
            "parameters": {
                "type": "object",
                "properties": {
                    "format": {"type": "string", "enum": {{ reports | tojson }}, "default": "html"},
                },
            },
        },
    },
{% endfor %}
{% for tool in additional_tools %}
    {
        "type": "function",
        "function": {
            "name": "{{ tool.name }}",
            "description": "{{ tool.description | default('Custom tool') }}",
            "parameters": {{ tool.parameters | default('{"type": "object", "properties": {}}') | tojson if tool.parameters is string else tool.parameters | default({"type": "object", "properties": {}}) | tojson }},
        },
    },
{% endfor %}
]

TOOL_MAP: dict[str, Any] = {
{% for domain in _all_domains %}
    "run_{{ domain }}_assessment": tool_run_{{ domain }}_assessment,
{% endfor %}
{% for tool in additional_tools %}
    "{{ tool.name }}": tool_{{ tool.name }},
{% endfor %}
}


# ── Agent message handler ──────────────────────────────────────────

SYSTEM_PROMPT = """You are {{ project_name }}, an AI-powered assessment assistant.
You help users run assessments, analyse findings, and generate reports.

Available assessment domains: {{ _all_domains | join(', ') }}

When a user asks for an assessment, call the appropriate tool.
Always provide actionable recommendations based on findings.
"""


async def handle_message(user_message: str) -> AsyncGenerator[dict, None]:
    """Process a user message with function-calling loop."""
    client = _get_client()
    deployment = os.getenv("AZURE_OPENAI_DEPLOYMENT", "{{ azure.models.primary | default('gpt-4.1') }}")

    messages = [
        {"role": "system", "content": SYSTEM_PROMPT},
        {"role": "user", "content": user_message},
    ]

    for round_num in range(MAX_ROUNDS):
        response = await client.chat.completions.create(
            model=deployment,
            messages=messages,
            tools=TOOL_SCHEMAS if TOOL_SCHEMAS else None,
        )

        choice = response.choices[0]

        if choice.finish_reason == "tool_calls":
            for tc in choice.message.tool_calls:
                fn_name = tc.function.name
                fn_args = json.loads(tc.function.arguments) if tc.function.arguments else {}

                yield {"type": "tool", "name": fn_name, "round": round_num + 1}

                fn = TOOL_MAP.get(fn_name)
                if fn:
                    result = await fn(**fn_args)
                else:
                    result = {"error": f"Unknown tool: {fn_name}"}

                messages.append(choice.message)
                messages.append({
                    "role": "tool",
                    "tool_call_id": tc.id,
                    "content": json.dumps(result, default=str),
                })

                # Emit report table if result contains findings
                if isinstance(result, dict) and "findings" in result:
                    yield {"type": "report_table", "data": result}

        else:
            # Final text response
            content = choice.message.content or ""
            yield {"type": "response", "content": content}

            # Token usage
            if response.usage:
                yield {
                    "type": "token_usage",
                    "prompt_tokens": response.usage.prompt_tokens,
                    "completion_tokens": response.usage.completion_tokens,
                }
            break
